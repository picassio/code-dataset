# =============================================================================
# Code Dataset - Secrets
# =============================================================================
# Copy to .env (or ~/.code-dataset/.env for global config).
# NEVER commit the actual .env file.

# --- API Keys (used when not using OAuth) ---
# ANTHROPIC_API_KEY=sk-ant-api-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=AIza...

# --- OAuth tokens (usually auto-managed via 'code-dataset auth login') ---
# ANTHROPIC_OAUTH_TOKEN=sk-ant-oat-...

# --- Optional overrides ---
# CODE_DATASET_PROVIDER=anthropic
# CODE_DATASET_MODEL=claude-sonnet-4-20250514
# CODE_DATASET_OUTPUT_DIR=./output
# CODE_DATASET_LOG_LEVEL=DEBUG
